# ============================================================
# AI Investment Memo Generator — Environment Configuration
# Copy this to .env and fill in values
# ============================================================

# Application
APP_NAME="AI Investment Memo Generator"
ENVIRONMENT=development
DEBUG=true

# Security — CHANGE IN PRODUCTION (run: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=memo_db
POSTGRES_USER=memo_user
POSTGRES_PASSWORD=memo_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Qdrant Vector DB
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=memo_chunks
QDRANT_VECTOR_SIZE=1536

# MinIO Object Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=pitch-decks
MINIO_SECURE=false

# OpenAI (primary LLM)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Qwen / custom OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.qwen.ai/v1
# OPENAI_MODEL=qwen-max

# Document Processing
CHUNK_SIZE=800
CHUNK_OVERLAP=100
MAX_PDF_PAGES=200
USE_OCR_FALLBACK=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
