# ============================================================
# AI Investment Memo Generator — Environment Configuration
# Copy to .env for local dev. Set these directly in Railway/Vercel dashboards.
# ============================================================

# ── Application ────────────────────────────────────────────
APP_NAME="AI Investment Memo Generator"
ENVIRONMENT=development          # production | development
DEBUG=true                       # set false in production

# ── Security ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list. Add your Vercel frontend URL in production.
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Database ───────────────────────────────────────────────
# OPTION A (Railway / cloud): Set DATABASE_URL directly — overrides all POSTGRES_* vars
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# OPTION B (local Docker): Use component vars
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=memo_db
POSTGRES_USER=memo_user
POSTGRES_PASSWORD=memo_password

# ── Redis ──────────────────────────────────────────────────
# OPTION A (Railway / Upstash): Set REDIS_URL directly
# REDIS_URL=redis://default:password@host:6379

# OPTION B (local Docker):
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Celery ─────────────────────────────────────────────────
# Update these to match your Redis URL in production
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Qdrant Vector DB ───────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=memo_chunks
QDRANT_VECTOR_SIZE=1536

# ── MinIO Object Storage ───────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=pitch-decks
MINIO_SECURE=false

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Document Processing ────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
MAX_PDF_PAGES=200
USE_OCR_FALLBACK=true

# ── Frontend (set in Vercel dashboard, not here) ───────────
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app
